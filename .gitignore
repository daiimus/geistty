*.a
*.o
*.dylib

# Xcode
build/
DerivedData/
*.xcuserstate
*.xcscmblueprint
xcuserdata/
*.xcresult
*.xcresult/

# Apple build products
*.app
*.ipa
*.dSYM
*.dSYM.zip
*.xcarchive

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Swift Package Manager
.build/
.swiftpm/
Package.resolved

# CocoaPods
Pods/

# Carthage
Carthage/Build/

# IDE
*.swp
*.swo
*~
.idea/
.vscode/

# Playgrounds
timeline.xctimeline
playground.xcworkspace

# Fastlane
fastlane/report.xml
fastlane/Preview.html
fastlane/screenshots/**/*.png
fastlane/test_output

# Test results and screenshots
test_results/
Geistty/test_results/

# Code Injection
iOSInjectionProject/

# ===========================================
# SENSITIVE FILES — NEVER COMMIT
# ===========================================

# SSH Keys and Certificates
*.pem
*.key
*.p12
*.pfx
*.cer
*.mobileprovision
id_rsa
id_rsa.*
id_ed25519
id_ed25519.*
*.ppk

# Test credentials and configs
test_credentials.json
test_config.json
TestCredentials.swift
test_secrets/
secrets/
.secrets
.env
.env.*
*.env

# Local test configuration (create from .example template)
TestConfig.local.swift
LocalTestConfig.swift
Geistty/GeisttyUITests/TestConfig.local.swift

# SSH known hosts and config for testing
test_known_hosts
test_ssh_config

# OpenCode private notes (device IDs, keychain paths, etc.)
.opencode/

